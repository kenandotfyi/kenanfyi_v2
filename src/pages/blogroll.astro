---
import BazPages from "../layouts/BazPages.astro";
import { createHash } from "crypto";

const pageTitle = "blogroll";

const COMMAFEED_USER = import.meta.env.COMMAFEED_USER;
const COMMAFEED_APIKEY = import.meta.env.COMMAFEED_APIKEY;
const COMMAFEED_URL = import.meta.env.COMMAFEED_URL;

// CommaFeed Fever API requires api_key = MD5(username:apiKey)
const apiKey = createHash("md5")
    .update(`${COMMAFEED_USER}:${COMMAFEED_APIKEY}`)
    .digest("hex");

let blogs: { name: string; url: string }[] = [];

try {
    const body = new URLSearchParams({ api_key: apiKey });

    const resp = await fetch(`${COMMAFEED_URL}?groups&feeds&feeds_groups`, {
        method: "POST",
        body,
    });
    const data = await resp.json();

    if (!data.auth) throw new Error("Fever API authentication failed");

    const blogsGroup = (data.groups ?? []).find(
        (g: any) => g.title.toLowerCase() === "blogs",
    );

    if (blogsGroup) {
        const groupFeeds = (data.feeds_groups ?? []).find(
            (fg: any) => fg.group_id === blogsGroup.id,
        );
        const feedIds = new Set(
            groupFeeds?.feed_ids?.split(",").map(Number) ?? [],
        );
        blogs = (data.feeds ?? [])
            .filter((f: any) => feedIds.has(f.id))
            .map((f: any) => {
                const raw = f.site_url ?? f.url;
                const url = (() => {
                    try {
                        return new URL(raw).origin;
                    } catch {
                        return raw;
                    }
                })();
                return { name: f.title, url };
            });
    }
} catch (e) {
    console.error("Failed to fetch blogroll from Fever API:", e);
}
---

<BazPages
    pageTitle={pageTitle}
    heroText="BLOGROLL"
    heroImage="/heros/hero-blogroll.png"
>
    <div class="archive-label">
        {blogs.length} blogs, in no particular order
    </div>

    <p class="blogs-para">
        {
            blogs.map((blog, i) => (
                <>
                    <a href={blog.url} target="_blank">
                        {blog.name}
                    </a>
                    {i < blogs.length - 1 && (
                        <span class="sep">&nbsp;&nbsp;/&nbsp;&nbsp;</span>
                    )}
                </>
            ))
        }
    </p>
</BazPages>

<style>
    .archive-label {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--fg-muted);
        margin-bottom: 1.25rem;
    }

    .blogs-para {
        line-height: 1.8;
        font-size: var(--text-base);
        margin: 0;
    }

    .sep {
        color: var(--border-default);
        user-select: none;
    }
</style>
