---
import BazPages from "../layouts/BazPages.astro";

const Hardcover = import.meta.env.HARDCOVER;

var bearer = "Bearer " + Hardcover;

const query = `
{
  me {
    user_books(order_by: [{status_id: asc}, {created_at: desc}]) {
      rating
      review_raw
      status_id
      book {
        id
        title
        slug
        pages
        release_year
        cached_contributors
        image {
          url
          height
          width
        }
      }
    }
  }
}`;

interface BookItem {
    rating: number;
    review_raw: string;
    status_id: number;
    book: {
        id: number;
        title: string;
        slug: string;
        pages: number;
        release_year: number;
        cached_contributors: { author: { name: string } }[];
        image: {
            url: string;
            height: number;
            width: number;
        };
    };
}

const statusLabels: Record<number, string> = {
    1: "Want to read",
    2: "Currently Reading",
    3: "Read",
    5: "Did not finish",
};

const response = await fetch("https://api.hardcover.app/v1/graphql", {
    method: "POST",
    headers: {
        Authorization: bearer,
        "Content-Type": "application/json",
    },
    body: JSON.stringify({ query }),
});

const d = await response.json();
const books = d.data.me[0];

const booksByStatus = books.user_books.reduce(
    (acc: Record<number, BookItem[]>, item: BookItem) => {
        if (!acc[item.status_id]) acc[item.status_id] = [];
        acc[item.status_id].push(item);
        return acc;
    },
    {},
);
const statusOrder = [2, 1, 3, 5]; // Reading, Want to read, Read, DNF
const statuses = statusOrder.filter((s) => booksByStatus[s]);

const pageTitle = "library";
---

<BazPages
    pageTitle={pageTitle}
    heroText="LIBRARY"
    heroImage="/heros/hero-library.png"
>
    <div id="preview" class="preview">
        <img id="preview-img" src="" alt="" />
    </div>

    <div class="books-list">
        {
            statuses.map((statusId) => {
                const books = booksByStatus[statusId].map((item: BookItem) => (
                    <a
                        href={`https://hardcover.app/books/${item.book.slug}`}
                        target="_blank"
                        class="book-item"
                        data-cover={item.book.image?.url || ""}
                    >
                        <div class="book-content">
                            <span class="book-title">{item.book.title}</span>
                            <span class="book-meta">
                                <span class="book-author">
                                    {item.book.cached_contributors?.[0]?.author
                                        ?.name || ""}
                                </span>
                                {item.book.release_year && (
                                    <span class="book-year">
                                        {item.book.release_year}
                                    </span>
                                )}
                                {item.rating && (
                                    <span class="book-rating">
                                        {"★".repeat(item.rating)}
                                    </span>
                                )}
                            </span>
                            {item.review_raw && (
                                <span class="book-review">
                                    {item.review_raw}
                                </span>
                            )}
                        </div>
                    </a>
                ));

                return statusId === 2 || statusId === 3 ? (
                    <section class="status-section" data-status={statusId}>
                        <div class="status-header">
                            <span class="status-label">
                                {statusLabels[statusId]}
                            </span>
                            <span class="status-count">
                                {booksByStatus[statusId].length}
                            </span>
                        </div>
                        {books}
                    </section>
                ) : (
                    <details class="status-section" data-status={statusId}>
                        <summary class="status-header">
                            <span class="status-left">
                                <span class="toggle-icon" aria-hidden="true" />
                                <span class="status-label">
                                    {statusLabels[statusId]}
                                </span>
                            </span>
                            <span class="status-count">
                                {booksByStatus[statusId].length}
                            </span>
                        </summary>
                        {books}
                    </details>
                );
            })
        }
    </div>
</BazPages>

<script>
    const preview = document.getElementById("preview") as HTMLElement;
    const previewImg = document.getElementById(
        "preview-img",
    ) as HTMLImageElement;

    const isMobile = () => window.innerWidth <= 768;

    document.querySelectorAll<HTMLElement>(".book-item").forEach((item) => {
        item.addEventListener("mouseenter", () => {
            if (isMobile()) return;
            const cover = item.dataset.cover;
            if (!cover) return;
            previewImg.src = cover;
            previewImg.onload = () => preview.classList.add("visible");
            previewImg.onerror = () => preview.classList.remove("visible");
        });

        item.addEventListener("mouseleave", () => {
            preview.classList.remove("visible");
        });

        item.addEventListener("mousemove", (e) => {
            const offset = 20;
            const x = e.clientX + offset;
            const y = e.clientY + offset;
            const pw = preview.offsetWidth;
            const ph = preview.offsetHeight;
            preview.style.left =
                (x + pw > window.innerWidth ? e.clientX - pw - offset : x) +
                "px";
            preview.style.top =
                (y + ph > window.innerHeight ? e.clientY - ph - offset : y) +
                "px";
        });
    });
</script>

<style>
    .preview {
        position: fixed;
        width: 200px;
        aspect-ratio: 2 / 3;
        border: 1px solid var(--border-subtle);
        overflow: hidden;
        pointer-events: none;
        opacity: 0;
        z-index: 9999;
        transition: opacity 0.15s ease;
        box-shadow: var(--shadow-lg);
    }

    .preview.visible {
        opacity: 1;
    }

    .preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .books-list {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
        margin-top: 1.5rem;
    }

    .status-section {
        display: flex;
        flex-direction: column;
    }

    details.status-section > summary {
        list-style: none;
        cursor: pointer;
        user-select: none;
    }

    details.status-section > summary::-webkit-details-marker {
        display: none;
    }

    .status-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding-bottom: 0.4rem;
        border-bottom: 1px solid var(--border-subtle);
        margin-bottom: 0;
    }

    .status-section[data-status="2"] .status-header {
        border-bottom-color: var(--accent);
    }

    .status-label {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--fg-primary);
    }

    .status-section[data-status="2"] .status-label {
        color: var(--accent);
    }

    .status-left {
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }

    .status-count {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
    }

    .toggle-icon {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        display: inline-block;
        transition: transform 0.2s ease;
    }

    .toggle-icon::before {
        content: "›";
    }

    details[open] > summary .toggle-icon {
        transform: rotate(90deg);
    }

    .book-item {
        display: flex;
        padding: 0.65rem 0;
        border-bottom: 1px solid var(--border-subtle);
        text-decoration: none;
        color: inherit;
    }

    .book-content {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
        flex: 1;
    }

    .book-title {
        font-family: var(--font-sans);
        font-size: var(--text-base);
        color: var(--fg-primary);
        line-height: 1.3;
        transition: color 0.15s ease;
    }

    .book-item:hover .book-title {
        color: var(--accent);
    }

    .book-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    .book-author {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
    }

    .book-year {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        opacity: 0.6;
    }

    .book-rating {
        font-size: var(--text-xs);
        color: var(--accent);
        letter-spacing: 1px;
    }

    .book-review {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        font-style: italic;
        color: var(--fg-secondary);
        margin-top: 0.25rem;
        padding-left: 0.75rem;
        border-left: 2px solid var(--border-subtle);
        line-height: 1.5;
    }
</style>
