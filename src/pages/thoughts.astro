---
import { getCollection, render } from "astro:content";
import BazPages from "../layouts/BazPages.astro";
import { Icon } from "astro-icon/components";
import PostBadge from "../components/PostBadge.astro";

const allThoughts = await getCollection(
    "thoughts",
    ({ data }) => data.draft !== true,
);
allThoughts.sort(
    (a, b) => b.data.published.getTime() - a.data.published.getTime(),
);
const pageTitle = "thoughts";

const withReadingTime = await Promise.all(
    allThoughts.map(async (post) => {
        const { remarkPluginFrontmatter } = await render(post);
        return {
            post,
            minutesRead: remarkPluginFrontmatter.minutesRead as string,
        };
    }),
);

const featured = withReadingTime[0];
const rest = withReadingTime.slice(1);

const postsByYear = rest.reduce((acc: Record<string, typeof rest>, item) => {
    const year = item.post.data.published.getFullYear().toString();
    if (!acc[year]) acc[year] = [];
    acc[year].push(item);
    return acc;
}, {});
const years = Object.keys(postsByYear).sort((a, b) => Number(b) - Number(a));
---

<BazPages
    pageTitle={pageTitle}
    heroText="THOUGHTS"
    heroImage="/heros/hero-thoughts.png"
>
    {
        featured && (
            <div class="featured">
                <div class="featured-meta">
                    <span class="meta-label">Latest</span>
                    <span class="meta-sep">—</span>
                    <time class="meta-item">
                        {featured.post.data.published.toLocaleDateString(
                            "en-US",
                            {
                                day: "2-digit",
                                month: "short",
                                year: "numeric",
                            },
                        )}
                    </time>
                    <span class="meta-sep">
                        <Icon name="ph:dot-duotone" size="28" />
                    </span>
                    <span class="meta-item">{featured.minutesRead}</span>
                </div>
                <a
                    href={`/thoughts/${featured.post.id}/`}
                    class="featured-title"
                >
                    {featured.post.data.title}
                </a>
                <p class="featured-desc">{featured.post.data.description}</p>
                {featured.post.data.tags.length > 0 && (
                    <div class="featured-tags">
                        {featured.post.data.tags.map((tag: string) => (
                            <span class="tag">#{tag}</span>
                        ))}
                    </div>
                )}
            </div>
        )
    }

    <div class="archive">
        <div class="archive-label">Archive</div>
        {
            years.map((year) => (
                <div class="year-group">
                    <div class="year-label">{year}</div>
                    {postsByYear[year].map(({ post, minutesRead }) => (
                        <a href={`/thoughts/${post.id}/`} class="post-row">
                            <time class="post-date">
                                {post.data.published.toLocaleDateString(
                                    "en-US",
                                    {
                                        day: "2-digit",
                                        month: "short",
                                    },
                                )}
                            </time>
                            <span class="post-title">
                                <Icon name="ph:feather-duotone" size="13" />
                                <span>{post.data.title}</span>
                                <PostBadge published={post.data.published} updated={post.data.updated} />
                            </span>
                            <span class="post-read">{minutesRead}</span>
                        </a>
                    ))}
                </div>
            ))
        }
    </div>
</BazPages>

<style>
    /* Featured post */
    .featured {
        padding: 2rem;
        margin-bottom: 2rem;
        border: 1px solid var(--border-subtle);
        border-radius: var(--border-s);
    }

    .featured-meta {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.75rem;
        font-family: var(--font-mono);
        font-size: var(--text-xs);
    }

    .meta-label {
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--accent);
    }

    .meta-sep {
        color: var(--border-default);
    }

    .meta-item {
        color: var(--fg-muted);
    }

    .featured-title {
        display: block;
        font-family: var(--font-display);
        font-size: 2rem;
        font-weight: 400;
        color: var(--fg-bright);
        text-decoration: none;
        margin-bottom: 0.75rem;
        line-height: 1.2;
        transition: color 0.15s ease;

        &:hover {
            color: var(--accent);
        }
    }

    .featured-desc {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--fg-muted);
        line-height: 1.6;
        margin: 0 0 0.75rem;
    }

    .featured-tags {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    .tag {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        letter-spacing: 0.05em;
    }

    /* Archive */
    .archive {
        display: flex;
        flex-direction: column;
    }

    .archive-label {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--fg-muted);
        margin-bottom: 1.25rem;
    }

    .year-group {
        margin-bottom: 1.75rem;
    }

    .year-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
        padding-bottom: 2px;
        margin-bottom: 4px;
        border-bottom: 1px solid var(--border-subtle);
    }

    .post-row {
        display: grid;
        grid-template-columns: 7ch 1fr auto;
        align-items: baseline;
        padding: 2px 0;
        text-decoration: none;

        &:hover .post-title {
            color: var(--accent);
        }
    }

    .post-date {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
    }

    .post-title {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-family: var(--font-base);
        font-size: var(--text-base);
        color: var(--fg-primary);
        transition: color 0.15s ease;
    }

    .post-title :global(svg) {
        opacity: 0.4;
        flex-shrink: 0;
    }

    .post-title span {
        text-decoration: underline;
        text-decoration-style: dotted;
        text-decoration-color: var(--accent);
        text-decoration-thickness: 1px;
        text-underline-offset: 3px;
    }

    .post-read {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        text-align: right;
    }

    @media (max-width: 600px) {
        .featured-title {
            font-size: 1.5rem;
        }

        .post-row {
            grid-template-columns: 6ch 1fr auto;
            gap: 0.5rem;
        }
    }
</style>
