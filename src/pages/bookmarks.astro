---
import BazPages from "../layouts/BazPages.astro";
import { Icon } from "astro-icon/components";
import { createHash } from "crypto";
import { writeFileSync, existsSync, mkdirSync } from "fs";
import { join } from "path";
import sharp from "sharp";

const RDAPIKEY = import.meta.env.RDAPIKEY;
const collectionId = import.meta.env.RDCOLLECTIONID;

const bearer = "Bearer " + RDAPIKEY;

interface RaindropItem {
    link: string;
    title: string;
    note: string;
    excerpt: string;
    created: string;
    cover: string;
    domain: string;
}

async function fetchAllLinks() {
    const items: RaindropItem[] = [];
    let page = 0;
    while (true) {
        const data = await fetch(
            `https://api.raindrop.io/rest/v1/raindrops/${collectionId}?perpage=50&page=${page}`,
            {
                method: "GET",
                headers: {
                    Authorization: bearer,
                    "Content-Type": "application/json",
                },
            },
        ).then((r) => r.json());
        items.push(...data.items);
        if (items.length >= data.count) break;
        page++;
    }
    return items;
}

// get the images from the raindrop API, resize + compress to webp, and cache locally.
// hashing guards against name collisions across different source domains.

async function downloadCover(url: string): Promise<string> {
    const hash = createHash("md5").update(url).digest("hex").slice(0, 12);
    const dir = join(process.cwd(), "public/covers");
    const filename = `${hash}.webp`;
    const filepath = join(dir, filename);

    if (existsSync(filepath)) return `/covers/${filename}`;
    if (!existsSync(dir)) mkdirSync(dir, { recursive: true });

    try {
        const res = await fetch(url);
        if (!res.ok) return "";
        const ct = res.headers.get("content-type") || "";
        if (!ct.startsWith("image/")) return "";
        const buffer = Buffer.from(await res.arrayBuffer());
        const optimized = await sharp(buffer)
            .resize({ width: 400, withoutEnlargement: true })
            .webp({ quality: 80 })
            .toBuffer();
        writeFileSync(filepath, optimized);
        return `/covers/${filename}`;
    } catch {
        return "";
    }
}

// fetch links from Raindrop first and then put them in the items[], with downloaded covers.
const rawItems = await fetchAllLinks();
const items: RaindropItem[] = await Promise.all(
    rawItems.map(async (item: RaindropItem) => ({
        ...item,
        cover: item.cover ? await downloadCover(item.cover) : "",
    })),
);

// don't write www. to the list items, it is ugly.
function getDomain(url: string) {
    try {
        return new URL(url).hostname.replace("www.", "");
    } catch {
        return url;
    }
}

const pageTitle = "bookmarks";
---

<BazPages
    pageTitle={pageTitle}
    heroText="BOOKMARKS"
    heroImage="/heros/hero-bookmarks.png"
>
    <div id="preview" class="preview">
        <img id="preview-img" src="" alt="" />
    </div>

    <div class="list-header">
        <span class="list-count">{items.length} links</span>
        <span class="list-date-label">Bookmarked at</span>
    </div>

    <ol class="links-list">
        {
            items.map((item: RaindropItem, i: number) => (
                <li>
                    <a
                        href={item.link}
                        target="_blank"
                        class="link-item"
                        data-cover={item.cover || ""}
                    >
                        <span class="link-index">
                            {String(i + 1).padStart(2, "0")}
                        </span>
                        <div class="link-content">
                            <span class="link-title">{item.title}</span>
                            <span class="link-meta">
                                <span class="link-domain">
                                    {getDomain(item.link)}
                                </span>
                                {item.note && (
                                    <span class="link-note">{item.note}</span>
                                )}
                            </span>
                        </div>
                        <time class="link-date">
                            {new Date(item.created).toLocaleDateString(
                                "en-US",
                                {
                                    day: "2-digit",
                                    month: "short",
                                    year: "numeric",
                                },
                            )}
                        </time>
                    </a>
                </li>
            ))
        }
    </ol>
</BazPages>

<script>
    const preview = document.getElementById("preview") as HTMLElement;
    const previewImg = document.getElementById(
        "preview-img",
    ) as HTMLImageElement;

    const isMobile = () => window.innerWidth <= 768;

    document.querySelectorAll<HTMLElement>(".link-item").forEach((item) => {
        item.addEventListener("mouseenter", () => {
            if (isMobile()) return;
            const cover = item.dataset.cover;
            if (!cover) return;
            previewImg.src = cover;
            previewImg.onload = () => preview.classList.add("visible");
            previewImg.onerror = () => preview.classList.remove("visible");
        });

        item.addEventListener("mouseleave", () => {
            preview.classList.remove("visible");
        });

        item.addEventListener("mousemove", (e) => {
            const offset = 20;
            const x = e.clientX + offset;
            const y = e.clientY + offset;
            const pw = preview.offsetWidth;
            const ph = preview.offsetHeight;
            preview.style.left =
                (x + pw > window.innerWidth ? e.clientX - pw - offset : x) +
                "px";
            preview.style.top =
                (y + ph > window.innerHeight ? e.clientY - ph - offset : y) +
                "px";
        });
    });
</script>

<style>
    .preview {
        position: fixed;
        width: 380px;
        aspect-ratio: 16 / 9;
        border: 1px solid var(--border-subtle);
        overflow: hidden;
        pointer-events: none;
        opacity: 0;
        z-index: 9999;
        transition: opacity 0.15s ease;
        box-shadow: var(--shadow-lg);
    }

    .preview.visible {
        opacity: 1;
    }

    .preview img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .list-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border-subtle);
        margin-top: 1.5rem;
    }

    .list-count {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .list-date-label {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        opacity: 0.5;
    }

    .links-list {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .link-item {
        display: grid;
        grid-template-columns: 3ch 1fr auto;
        gap: 0.75rem;
        align-items: start;
        padding: 0.7rem 0;
        border-bottom: 1px solid var(--border-subtle);
        text-decoration: none;
        color: inherit;
    }

    .link-index {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        padding-top: 0.15rem;
        letter-spacing: 0.04em;
    }

    .link-content {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
    }

    .link-title {
        font-family: var(--font-display);
        font-size: var(--text-base);
        color: var(--fg-primary);
        line-height: 1.3;
        transition: color 0.15s ease;
    }

    .link-item:hover .link-title {
        color: var(--accent);
    }

    .link-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: wrap;
    }

    .link-domain {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
    }

    .link-note {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        font-style: italic;
        opacity: 0.7;
    }

    .link-note::before {
        content: "— ";
    }

    .link-date {
        font-family: var(--font-mono);
        font-size: var(--text-xs);
        color: var(--fg-muted);
        opacity: 0.5;
        white-space: nowrap;
        padding-top: 0.2rem;
        text-align: right;
    }

    @media (max-width: 600px) {
        .link-item {
            grid-template-columns: 3ch 1fr;
        }

        .link-date {
            display: none;
        }
    }
</style>
