---
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const currentPath = Astro.url.pathname;

const allThoughts = await getCollection("thoughts", ({ data }) => !data.draft);
const allBits = await getCollection("bits", ({ data }) => !data.draft);

const recentPosts = [
    ...allThoughts.map((p) => ({
        id: p.id,
        title: p.data.title,
        published: p.data.published,
        collection: "thoughts",
    })),
    ...allBits.map((p) => ({
        id: p.id,
        title: p.data.title,
        published: p.data.published,
        collection: "bits",
    })),
]
    .sort((a, b) => b.published.getTime() - a.published.getTime())
    .slice(0, 5);

// Recent bookmarks
interface NavLink {
    title: string;
    link: string;
    domain: string;
}
let recentLinks: NavLink[] = [];
try {
    const RDAPIKEY = import.meta.env.RDAPIKEY;
    const collectionId = import.meta.env.RDCOLLECTIONID;
    const resp = await fetch(
        `https://api.raindrop.io/rest/v1/raindrops/${collectionId}?perpage=5`,
        {
            method: "GET",
            headers: {
                Authorization: `Bearer ${RDAPIKEY}`,
                "Content-Type": "application/json",
            },
        },
    );
    const data = await resp.json();
    recentLinks = (data.items ?? []).slice(0, 5).map((item: any) => ({
        title: item.title,
        link: item.link,
        domain: new URL(item.link).hostname.replace("www.", ""),
    }));
} catch {}

// Currently reading
interface NavBook {
    title: string;
    slug: string;
    author: string;
    coverUrl: string;
}
let currentlyReading: NavBook | null = null;
try {
    const query = `{ me { user_books(where: {status_id: {_eq: 2}}, limit: 1, order_by: [{updated_at: desc}]) { book { title slug cached_contributors image { url } } } } }`;
    const resp = await fetch("https://api.hardcover.app/v1/graphql", {
        method: "POST",
        headers: {
            Authorization: `Bearer ${import.meta.env.HARDCOVER}`,
            "Content-Type": "application/json",
        },
        body: JSON.stringify({ query }),
    });
    const data = await resp.json();
    const book = data?.data?.me?.[0]?.user_books?.[0]?.book;
    if (book) {
        currentlyReading = {
            title: book.title,
            slug: book.slug,
            author: book.cached_contributors?.[0]?.author?.name ?? "",
            coverUrl: book.image?.url ?? "",
        };
    }
} catch {}

const navLinks = [
    { href: "/thoughts/", label: "THOUGHTS" },
    { href: "/bits/", label: "BITS" },
    { href: "/library/", label: "LIBRARY" },
    { href: "/bookmarks/", label: "BOOKMARKS" },
    { href: "/blogroll/", label: "BLOGROLL" },
    { href: "/about/", label: "ABOUT" },
];

const isActive = (href: string) => {
    if (href === "/") return currentPath === "/";
    return currentPath.startsWith(href);
};
---

<nav class="top-nav">
    <div class="nav-inner">
        <div class="nav-bar">
            <div class="nav-left">
                <a href="/" class="nav-logo">
                    <img src="/logo.svg" alt="" width="25" />
                </a>
                {
                    navLinks.map(({ href, label }) => (
                        <a
                            href={href}
                            class:list={[
                                "nav-toggle",
                                "nav-page-link",
                                { active: isActive(href) },
                            ]}
                        >
                            {label.toUpperCase()}
                        </a>
                    ))
                }
                <button
                    class="nav-toggle"
                    id="nav-toggle"
                    aria-label="Toggle navigation"
                    aria-expanded="false"
                >
                    <!-- <Icon name="ph:shovel-duotone" size="18" /> -->
                    MORE ~
                </button>
            </div>
            <div class="nav-right">
                <button
                    id="theme-toggle"
                    class="theme-toggle"
                    aria-label="Toggle theme"
                >
                    <span class="icon-sun"
                        ><Icon name="ph:sun-duotone" size="18" /></span
                    >
                    <span class="icon-moon"
                        ><Icon name="ph:moon-duotone" size="18" /></span
                    >
                </button>
            </div>
        </div>

        <div class="nav-menu" id="nav-menu" aria-hidden="true">
            <div class="menu-section menu-section--mobile-pages">
                <div class="menu-label">Navigation</div>
                <p class="menu-items">
                    {
                        navLinks.map((link, i) => (
                            <>
                                <a
                                    href={link.href}
                                    class:list={[
                                        "menu-link",
                                        { active: isActive(link.href) },
                                    ]}
                                >
                                    {link.label}
                                </a>
                                {i < navLinks.length - 1 && (
                                    <span class="menu-slash"> / </span>
                                )}
                            </>
                        ))
                    }
                </p>
            </div>
            <div class="menu-section">
                <div class="menu-label">Recently Posted</div>
                <p class="menu-items">
                    {
                        recentPosts.map((post, i) => (
                            <>
                                <span class="menu-item-icon">
                                    {post.collection === "thoughts" ? (
                                        <Icon
                                            name="ph:feather-duotone"
                                            size="12"
                                        />
                                    ) : (
                                        <Icon
                                            name="ph:code-duotone"
                                            size="12"
                                        />
                                    )}
                                </span>
                                <a
                                    href={`/${post.collection}/${post.id}/`}
                                    class="menu-link"
                                >
                                    {post.title}
                                </a>
                                {i < recentPosts.length - 1 && (
                                    <span class="menu-slash"> / </span>
                                )}
                            </>
                        ))
                    }
                </p>
            </div>

            {
                recentLinks.length > 0 && (
                    <div class="menu-section">
                        <div class="menu-label">Recently Bookmarked</div>
                        <p class="menu-items">
                            {recentLinks.map((link, i) => (
                                <>
                                    <span class="menu-item-icon">
                                        <Icon
                                            name="ph:bookmarks-duotone"
                                            size="12"
                                        />
                                    </span>
                                    <a
                                        href={link.link}
                                        target="_blank"
                                        class="menu-link menu-link--muted"
                                    >
                                        {link.title}
                                    </a>
                                    {i < recentLinks.length - 1 && (
                                        <span class="menu-slash"> / </span>
                                    )}
                                </>
                            ))}
                        </p>
                    </div>
                )
            }

            {
                currentlyReading && (
                    <div class="menu-section">
                        <div class="menu-label">Currently Reading</div>
                        <p class="menu-items">
                            <>
                                <span class="menu-item-icon">
                                    <Icon
                                        name="ph:book-open-duotone"
                                        size="12"
                                    />
                                </span>
                                <a
                                    href={`https://hardcover.app/books/${currentlyReading.slug}`}
                                    target="_blank"
                                    class="menu-link"
                                >
                                    {currentlyReading.title}
                                </a>
                            </>
                            {currentlyReading.author && (
                                <span class="menu-reading-meta">
                                    {" "}
                                    — {currentlyReading.author}
                                </span>
                            )}
                        </p>
                    </div>
                )
            }

            <div class="menu-section">
                <div class="menu-label">Contact</div>
                <div class="menu-contact-icons">
                    <a
                        href="https://mas.to/@ingenieur"
                        class="menu-contact-icon"
                        rel="me"
                        aria-label="Mastodon"
                    >
                        <Icon name="ph:mastodon-logo-duotone" size="18" />
                    </a>
                    <a
                        href="https://github.com/kenandotfyi"
                        class="menu-contact-icon"
                        aria-label="GitHub"
                    >
                        <Icon name="ph:github-logo-duotone" size="18" />
                    </a>
                    <a
                        href="mailto:hey@kenan.fyi"
                        class="menu-contact-icon"
                        aria-label="Email"
                    >
                        <Icon name="ph:envelope-duotone" size="18" />
                    </a>
                    <a
                        href="/rss.xml"
                        class="menu-contact-icon"
                        aria-label="RSS"
                    >
                        <Icon name="ph:rss-duotone" size="18" />
                    </a>
                </div>
            </div>
        </div>
    </div>
</nav>

<script>
    const navToggle = document.getElementById("nav-toggle");
    const navMenu = document.getElementById("nav-menu");
    const themeToggle = document.getElementById("theme-toggle");

    navToggle?.addEventListener("click", () => {
        const isOpen = navMenu?.classList.contains("open");
        navMenu?.classList.toggle("open", !isOpen);
        navToggle.setAttribute("aria-expanded", String(!isOpen));
        navMenu?.setAttribute("aria-hidden", String(isOpen));
    });

    document.addEventListener("click", (e) => {
        if (
            navMenu?.classList.contains("open") &&
            !navMenu.contains(e.target as Node) &&
            !navToggle?.contains(e.target as Node)
        ) {
            navMenu.classList.remove("open");
            navToggle?.setAttribute("aria-expanded", "false");
            navMenu?.setAttribute("aria-hidden", "true");
        }
    });

    const navLogo = document.querySelector(".nav-logo") as HTMLElement | null;
    const mq = window.matchMedia("(min-width: 769px)");

    function updateLogoScroll() {
        if (mq.matches && window.scrollY > 0) {
            navLogo?.classList.add("scrolled");
        } else {
            navLogo?.classList.remove("scrolled");
        }
    }

    window.addEventListener("scroll", updateLogoScroll, { passive: true });
    mq.addEventListener("change", updateLogoScroll);
    updateLogoScroll();

    function getTheme() {
        return document.documentElement.getAttribute("data-theme") ?? "dark";
    }

    function setTheme(theme: string) {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);
    }

    themeToggle?.addEventListener("click", () => {
        setTheme(getTheme() === "light" ? "dark" : "light");
    });
</script>

<style>
    .top-nav {
        position: sticky;
        top: 0;
        z-index: 30;
        margin-left: calc(50% - 50vw);
        margin-right: calc(50% - 50vw);
    }

    .nav-inner {
        position: relative;
        max-width: 95ch;
        margin: 0 auto;
        padding: 1rem calc(var(--q) * 4);
    }

    .nav-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .nav-left {
        display: flex;
        align-items: center;
        gap: 2px;
    }

    .nav-logo {
        display: flex;
        align-items: center;
        line-height: 1;

        & img {
            display: block;
        }
    }

    .nav-toggle {
        display: flex;
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        align-items: center;
        justify-content: center;
        background: var(--bg-deep);
        border: 0;
        line-height: 1;
        border-radius: 2px;
        color: var(--text);
        cursor: pointer;
        padding: 5px 8px;
        text-decoration: none;
        transition: color 0.2s ease;

        & :global(svg) {
            display: block;
        }

        &:hover {
            color: var(--fg-primary);
        }

        &.active {
            color: var(--accent);
        }

        &[aria-expanded="true"] {
            color: var(--fg-muted);
        }
    }

    @media (max-width: 768px) {
        .nav-page-link {
            display: none;
        }
    }

    .nav-right {
        display: flex;
        align-items: center;
        gap: 4px;
    }

    /* Dropdown menu */
    .nav-menu {
        position: absolute;
        font-family: var(--font-mono);
        top: calc(3rem + 8px);
        left: calc(var(--q) * 4);
        right: calc(var(--q) * 4);
        z-index: 50;
        background-color: var(--bg-raised);
        border: 1px solid var(--border-subtle);
        padding: 1rem;
        opacity: 0;
        text-wrap: auto;
        visibility: hidden;
    }

    .nav-menu.open {
        opacity: 1;
        visibility: visible;
    }

    .menu-section {
        display: flex;
        flex-direction: column;
        gap: 4px;
        padding-bottom: calc(var(--q) * 5);

        &:last-child {
            padding-bottom: 0;
        }
    }

    @media (min-width: 769px) {
        .menu-section--mobile-pages {
            display: none;
        }
    }

    .menu-label {
        font-size: var(--text-xs);
        font-family: var(--font-mono);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--fg-muted);
    }

    .menu-items {
        margin: 0;
        padding: 0;
        line-height: 1.8;
        font-size: var(--text-xs);
    }

    .menu-link {
        color: var(--fg-primary);
        text-decoration: none;
        transition: color 0.15s ease;

        &:hover {
            color: var(--accent-bright);
        }

        &.active {
            color: var(--accent);
        }

        &.menu-link--muted {
            color: var(--fg-muted);
        }
    }

    .menu-slash {
        color: var(--border-default);
        user-select: none;
    }

    .menu-item-icon {
        display: inline-flex;
        vertical-align: -0.05em;
        margin-right: 2px;
        opacity: 0.4;

        & :global(svg) {
            display: block;
        }
    }

    .menu-reading-meta {
        color: var(--fg-muted);
    }

    .menu-contact-icons {
        display: flex;
        gap: 14px;
        align-items: center;
    }

    .menu-contact-icon {
        display: flex;
        color: var(--fg-muted);
        text-decoration: none;
        transition: color 0.15s ease;
        line-height: 0;

        & :global(svg) {
            display: block;
        }

        &:hover {
            color: var(--accent);
        }
    }

    /* Theme toggle */
    .theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        background: none;
        border: none;
        color: var(--fg-primary);
        cursor: pointer;
        transition: color 0.2s ease;
        line-height: 0;
        padding: 4px;

        & :global(svg) {
            display: block;
        }

        &:hover {
            color: var(--accent);
        }
    }

    :global(html:not([data-theme="light"])) .icon-moon {
        display: none;
    }
    :global(html[data-theme="light"]) .icon-sun {
        display: none;
    }
</style>
